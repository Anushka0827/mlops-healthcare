# ── Required ──────────────────────────────────────────────────────────────────
# Secret key for JWT signing — change this in production!
SECRET_KEY=change-me-in-prod-use-a-long-random-string

# ── Optional ──────────────────────────────────────────────────────────────────
# URL of the FastAPI backend (used by Streamlit UI)
API_URL=http://localhost:8000

# Token expiry in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30